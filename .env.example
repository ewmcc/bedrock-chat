# ── App credentials ──────────────────────────────────────────────
# Username and password used for the login page.
APP_USERNAME=
APP_PASSWORD=

# ── AWS credentials ───────────────────────────────────────────────
# Leave blank to use the default AWS credential chain
# (IAM role, ~/.aws/credentials, instance profile, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Bedrock model ────────────────────────────────────────────────
# Cross-region inference prefix (us.) is required for Claude 4 / 3.7+.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
